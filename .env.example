# ============================================================
# HRMS — Environment Configuration Template
# ============================================================
# Copy file ini ke .env lalu sesuaikan nilainya.
#   cp .env.example .env
# Jangan pernah commit .env ke repository!
# ============================================================

# ─── Database ───
DB_HOST=db
DB_PORT=5432
DB_USER=hrms
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
DB_NAME=hrms
DB_SSLMODE=disable

# ─── JWT ───
# Generate: openssl rand -hex 32
JWT_SECRET=<GENERATE_64_CHAR_HEX>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ─── Encryption (AES-256) ───
# WAJIB di-set! Generate: openssl rand -hex 16
# Jika kosong, auto-generate tapi data tidak terbaca setelah restart!
ENCRYPTION_KEY=<GENERATE_32_CHAR_HEX>

# ─── Server ───
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
FRONTEND_URL=http://localhost:8080

# ─── Storage ───
UPLOAD_DIR=./uploads

# ─── Redis (optional, fallback ke in-memory jika kosong) ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── SMTP (optional, untuk notifikasi email) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hrms.example.com
SMTP_FROM_NAME=HRMS System

# ─── Push Notification (optional, VAPID keys) ───
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
