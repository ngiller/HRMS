# ============================================================
# HRMS Application — Environment Variables
# Copy this file to .env and adjust values as needed
# ============================================================

# ---------- Database ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=magnum
DB_PASSWORD=Pass@w0rd
DB_NAME=hrms
DB_SSLMODE=disable

# ---------- JWT ----------
JWT_SECRET=hrms-super-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ---------- Server ----------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ---------- Frontend ----------
FRONTEND_URL=http://localhost:5173

# ---------- Encryption (data sensitif: NIK, NPWP, Bank) ----------
# WAJIB di-set! Generate dengan: openssl rand -hex 32
# Jika kosong, akan auto-generate random key tiap startup.
# PERINGATAN: Key yang auto-generate akan berubah setelah restart,
# menyebabkan data terenkripsi tidak bisa dibaca lagi!
ENCRYPTION_KEY=

# ---------- Storage ----------
UPLOAD_DIR=./uploads

# ---------- SMTP / Email Notification ----------
# Isi SMTP_HOST untuk mengaktifkan notifikasi email.
# Biarkan kosong jika tidak ingin menggunakan email.
# Untuk Gmail: gunakan App Password (bukan password biasa).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@hrms.com
# SMTP_FROM_NAME=HRMS System
