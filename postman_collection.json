	"item": [
		{
			"name": "🔐 Auth",
			"description": "Endpoint autentikasi — public, tidak perlu token.",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.collectionVariables.set('access_token', jsonData.data.access_token);",
									"    pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
									"    pm.collectionVariables.set('employee_id', jsonData.data.user.id);",
									"    console.log('Token tersimpan:', jsonData.data.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login dengan email & password.\nResponse: access_token, refresh_token, user data (ID, nama, email, role, permissions).\nAccess token otomatis disimpan ke variable `access_token`."
					}
				},
				{
					"name": "Login as Karyawan",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.collectionVariables.set('access_token', jsonData.data.access_token);",
									"    pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
									"    console.log('Token tersimpan');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"budi@company.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login sebagai role Karyawan (akses terbatas)."
					}
				},
				{
